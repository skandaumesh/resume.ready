# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# ─────────────────────────────────────────────────────────────

# Database — Supabase Postgres (Project Settings → Database → Connection string)
# Use the "Connection pooling" (pgbouncer) URL as DATABASE_URL for the app,
# and the direct connection URL as DIRECT_URL for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Clerk auth — https://dashboard.clerk.com  (API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Gemini (Google AI Studio free tier: 1,500 requests/day, no card) — PRIMARY
# AI provider. Get a key at https://aistudio.google.com → "Get API key".
# At least one of GEMINI_API_KEY / OPENROUTER_API_KEY must be set.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash,gemini-2.5-flash-lite"

# OpenRouter (free-tier AI) — FALLBACK provider when Gemini is unavailable.
# https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Free model(s) for generation — COMMA-SEPARATED list tried in order. Free models
# get rate-limited (429) constantly, so listing several lets the app fall through
# to the next when one is busy. The exact free list changes over time; browse
# current options at https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL="openai/gpt-oss-120b:free,google/gemma-4-31b-it:free,openai/gpt-oss-20b:free,meta-llama/llama-3.3-70b-instruct:free"

# Public site URL (used for OpenRouter attribution headers). Local dev default:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"